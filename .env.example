# ================================================
#  Discord Bot — Konfigurasi Environment
# ================================================
# Salin file ini menjadi .env dan isi semua nilainya

# ── WAJIB DIISI ──────────────────────────────────

# Token Bot Discord
# Dapatkan dari: https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Client ID Bot Discord (Application ID)
# Dapatkan dari: https://discord.com/developers/applications → General Information
CLIENT_ID=your_client_id_here

# API Key Groq (untuk fitur AI — GRATIS!)
# Dapatkan dari: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── OPSIONAL ─────────────────────────────────────

# YouTube Data API v3 Key (untuk fitur notifikasi YouTube)
# Dapatkan dari: https://console.developers.google.com → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Guild ID untuk deploy command ke server tertentu (lebih cepat saat development)
# Kosongkan untuk deploy global (butuh ~1 jam untuk menyebar)
GUILD_ID=your_guild_id_here

# Model Groq yang digunakan (default: llama-3.3-70b-versatile)
# Model tersedia (GRATIS semua!):
#   llama-3.3-70b-versatile  → Terbaik, paling pintar ⭐ RECOMMENDED
#   llama-3.1-8b-instant     → Paling cepat & ringan ⚡
#   llama3-70b-8192          → Konteks panjang (8192 token)
#   mixtral-8x7b-32768       → Konteks sangat panjang (32768 token)
#   gemma2-9b-it             → Google Gemma 2
GROQ_MODEL=llama-3.3-70b-versatile

# Interval pengecekan YouTube dalam menit (default: 5)
YT_CHECK_INTERVAL_MINUTES=5

# Batas maksimal subscription YouTube per server (default: 10)
MAX_YT_SUBSCRIPTIONS=10

# Batas maksimal pesan konteks AI per user (default: 10)
MAX_CONTEXT_MESSAGES=10

# Level log: error, warn, info, debug (default: info)
LOG_LEVEL=info
